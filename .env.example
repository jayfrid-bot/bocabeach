# No API keys are required for v1 — every data source in the default config is free
# and keyless (NOAA CO-OPS, NOAA NDBC, NWS api.weather.gov, Open-Meteo).
#
# Optional: richer surf/swell data from Stormglass.io (documented marine API,
# ~10 requests/day on the free, non-commercial tier). Leave unset to disable.
# STORMGLASS_API_KEY=

# Optional: override the FL Healthy Beaches Caspio DataPage appKey used by
# lib/sources/waterQuality.ts. Only needed if floridahealth.gov changes its
# embedded DataPage. Defaults to the current public appKey.
# FL_HEALTHY_BEACHES_APPKEY=

# Optional: HERE Traffic API v7 key for the per-beach "area traffic score"
# (https://platform.here.com — free tier available). Leave unset to disable;
# the Traffic card degrades to "—" and the rest of the page renders normally.
# Set this as a HOST project env var (Netlify/Vercel), NOT a GitHub Actions
# secret — the Next app fetches HERE live, server-side; no Action calls it.
# HERE_API_KEY=

# Some upstreams (notably api.weather.gov) ask for a descriptive User-Agent with
# contact info. Customize it for your deployment.
CONDITIONS_USER_AGENT="boca-beach-conditions (contact: you@example.com)"

# --- Push notifications (native apps only: iOS + Android) ------------------
# Notifications are delivered to the native apps — APNs on iOS, FCM on Android.
# The hourly GitHub Action (.github/workflows/push-cron.yml) calls POST
# /api/push/run with CRON_SECRET; the sender no-ops (503) until CRON_SECRET and
# at least one transport below are set, so a half-set-up deploy never sends.
# Device tokens persist in Netlify Blobs (dev: .push-native-store.json).

# Shared secret for the sender. Set the SAME value as a Netlify env var AND a
# GitHub repo secret CRON_SECRET. Optional repo var SITE_URL if not on isitbeachday.com.
# CRON_SECRET=

# iOS (APNs) — needs an APNs Auth Key (.p8) from the Apple Developer account
# (Certificates, IDs & Profiles → Keys → new key with "Apple Push Notifications
# service" enabled) + the Push Notifications capability in Xcode.
# APNS_KEY_ID=              # the Key ID of the .p8 key
# APNS_TEAM_ID=             # your Apple Developer Team ID
# APNS_PRIVATE_KEY=         # the .p8 contents (PEM); real newlines or \n-escaped
#   ↑ PEM starts with "-----" + is multi-line, which the Netlify CLI mangles. Easiest:
#   set the base64 form instead (single-line, CLI-safe) — it's preferred if present:
#   netlify env:set APNS_PRIVATE_KEY_B64 "$(openssl base64 -A -in AuthKey_XXXX.p8)"
# APNS_BUNDLE_ID=com.isitbeachday.app
# APNS_PRODUCTION=true      # "false" only for an Xcode dev build (sandbox); TestFlight/App Store = production

# Android (FCM) — needs a Firebase project. Download a service-account key
# (Firebase console → Project settings → Service accounts → Generate new private
# key) and copy these three fields out of the JSON. Also drop the project's
# google-services.json into android/app/ for the Android build.
# FCM_PROJECT_ID=           # "project_id" from the service-account JSON
# FCM_CLIENT_EMAIL=         # "client_email"
# FCM_PRIVATE_KEY=          # "private_key" (PEM); real newlines or \n-escaped
#   ↑ same gotcha as APNs — prefer the base64 form (set if present):
#   netlify env:set FCM_PRIVATE_KEY_B64 "$(printf '%s' "$PRIVATE_KEY_PEM" | openssl base64 -A)"
