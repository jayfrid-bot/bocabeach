# No API keys are required for v1 — every data source in the default config is free
# and keyless (NOAA CO-OPS, NOAA NDBC, NWS api.weather.gov, Open-Meteo).
#
# Optional: richer surf/swell data from Stormglass.io (documented marine API,
# ~10 requests/day on the free, non-commercial tier). Leave unset to disable.
# STORMGLASS_API_KEY=

# Optional: override the FL Healthy Beaches Caspio DataPage appKey used by
# lib/sources/waterQuality.ts. Only needed if floridahealth.gov changes its
# embedded DataPage. Defaults to the current public appKey.
# FL_HEALTHY_BEACHES_APPKEY=

# Optional: HERE Traffic API v7 key for the per-beach "area traffic score"
# (https://platform.here.com — free tier available). Leave unset to disable;
# the Traffic card degrades to "—" and the rest of the page renders normally.
# Set this as a HOST project env var (Netlify/Vercel), NOT a GitHub Actions
# secret — the Next app fetches HERE live, server-side; no Action calls it.
# HERE_API_KEY=

# Some upstreams (notably api.weather.gov) ask for a descriptive User-Agent with
# contact info. Customize it for your deployment.
CONDITIONS_USER_AGENT="boca-beach-conditions (contact: you@example.com)"

# --- Web Push notifications (optional) -------------------------------------
# Lets visitors get a morning "is it beach day" summary + safety alerts for a
# beach. Until these are set, the "Notify me" button shows as unavailable and
# the sender returns 503 (so a half-set-up deploy never sends).
#
# 1) Generate a keypair once:  npx web-push generate-vapid-keys
# 2) Set these as HOST (Netlify) env vars — the public key is safe to expose,
#    the private key is a server secret (never commit it):
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # the "publicKey" from step 1
# VAPID_PRIVATE_KEY=              # the "privateKey" — server only
# VAPID_SUBJECT=mailto:you@example.com
#
# 3) Shared secret the hourly GitHub Action uses to call POST /api/push/run.
#    Set the SAME value as a Netlify env var AND a GitHub repo secret CRON_SECRET
#    (see .github/workflows/push-cron.yml). Optional repo var SITE_URL if you're
#    not on isitbeachday.com.
# CRON_SECRET=
#
# Subscriptions persist in Netlify Blobs in production (zero-config); locally
# they fall back to a gitignored .push-store.json file.

# --- Native iOS push via APNs (optional) -----------------------------------
# Powers notifications in the native App Store app (the Capacitor shell), which
# can't use Web Push. Requires an APNs Auth Key (.p8) from the Apple Developer
# account (Certificates, IDs & Profiles → Keys → new key with "Apple Push
# Notifications service" enabled) plus the Push Notifications capability in the
# Xcode project. Set as HOST (Netlify) env vars; the sender no-ops until present.
# APNS_KEY_ID=              # the Key ID of the .p8 key
# APNS_TEAM_ID=             # your Apple Developer Team ID
# APNS_PRIVATE_KEY=         # the .p8 file contents (PEM). Paste with real
#                           # newlines, or escape them as \n on one line.
# APNS_BUNDLE_ID=com.isitbeachday.app
# APNS_PRODUCTION=true      # "false" only for Xcode dev builds (sandbox gateway);
#                           # TestFlight + App Store builds use production.
# Native device tokens persist in Netlify Blobs (dev: .push-native-store.json).
